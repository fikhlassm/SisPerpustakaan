# =====================================================
# Environment Variables — Perpustakaan UNAIR
# Copy file ini ke .env dan isi nilai-nilainya
# =====================================================

# Database (Prisma) — PostgreSQL via Supabase
# Dapatkan dari: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:6543/postgres"

# Session signing key — minimal 32 karakter acak
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=""

# URL aplikasi (untuk canonical links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
