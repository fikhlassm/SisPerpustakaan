# Database (Prisma)
# Gunakan path relatif dari root project agar cross-platform (Windows/Linux/macOS)
DATABASE_URL="file:./db/custom.db"

# Session signing key — WAJIB diset, minimal 32 karakter acak
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="5d42added497409f0484cad97e402fdef334cb036cf4fa6d6e1d35527e34fe899b273091f5bc4a27a72e3cf3c1299d8e789058fd745a9b1e1bb452e039b82048"

